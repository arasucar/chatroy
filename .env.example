# Copy to `.env` and fill in. Anything marked REQUIRED must be set before
# `docker compose up` — compose will fail fast with a clear error if not.
#
# Generate strong secrets with: `openssl rand -base64 32`

# ─── Public entry point ─────────────────────────────────────────────────────
# Domain Caddy serves over HTTPS. DNS must point here BEFORE first boot or
# Let's Encrypt will refuse to issue. (REQUIRED)
DOMAIN=roy.rxstud.io

# Let's Encrypt expiry notifications go here. (REQUIRED)
ACME_EMAIL=a.arasucar@gmail.com

# ─── Postgres ───────────────────────────────────────────────────────────────
# (REQUIRED)
POSTGRES_USER=roy
POSTGRES_PASSWORD=change-me-openssl-rand-base64-32
POSTGRES_DB=roy

# Full DATABASE_URL the app will use in Phase 1+. `postgres` is the compose
# service name on the internal network.
DATABASE_URL=postgres://roy:change-me-openssl-rand-base64-32@postgres:5432/roy

# ─── Redis ──────────────────────────────────────────────────────────────────
# (REQUIRED)
REDIS_PASSWORD=change-me-openssl-rand-base64-32
REDIS_URL=redis://:change-me-openssl-rand-base64-32@redis:6379

# ─── Ollama ─────────────────────────────────────────────────────────────────
# Where the app will reach Ollama on the compose network.
OLLAMA_BASE_URL=http://ollama:11434

# Models pulled by scripts/pull-models.sh. Keep in sync with that script.
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── App secrets (Phase 1+) ─────────────────────────────────────────────────
# Auth.js session signing key. Fill in before Phase 1. (REQUIRED in Phase 1)
AUTH_SECRET=

# Encryption key for user-provided API keys (Phase 6). libsodium secretbox;
# must be 32 bytes base64-encoded. Do NOT rotate without a migration plan —
# stored keys become unrecoverable.
USER_KEY_ENCRYPTION_KEY=

# ─── Observability (Phase 8) ────────────────────────────────────────────────
# SENTRY_DSN=
# LOG_LEVEL=info
